{
  "id": "7105baa7-5608-465e-874e-69c1ae0781e2",
  "name": "FieldOps Cortex Agent — Observability",
  "type": "dashboard",
  "content": {
    "version": 21,
    "variables": [],
    "tiles": {
      "0": {
        "type": "markdown",
        "content": "# FieldOps Cortex Agent — Observability\n\nSplit-stack telemetry for a Python FastAPI agent calling Snowflake Cortex Agents:\n\n- **OneAgent** ships host / Nginx / RUM / logs to this tenant.\n- **OpenLLMetry (Traceloop) → OTLP** ships `gen_ai.*` spans for the AI Observability app and this dashboard.\n\nSpan queries are scoped to `dt.service.name == \"fieldops-backend\"` (OTLP service entity). RUM queries are scoped to `page.title == \"FieldOps Copilot\"` + `dt.rum.user_type == \"real_user\"` (works for both the auto-detected and assigned application entities)."
      },
      "1": {
        "type": "data",
        "title": "Agent requests by role",
        "query": "fetch spans | filter dt.service.name == \"fieldops-backend\" and span.name == \"agent.run\" | makeTimeseries c = count(), by:{user.role}",
        "visualization": "lineChart",
        "visualizationSettings": {
          "dataMapping": { "time": "timeframe", "displayedFields": ["user.role"], "series": ["c"], "interval": "interval" },
          "axes": {
            "xAxis": { "label": "", "showLabel": false, "displayTimeFrame": "auto" },
            "yAxis": { "label": "requests", "min": {"mode": "auto"}, "max": {"mode": "auto"}, "scale": "linear", "showLabel": true }
          },
          "seriesConfig": { "curve": "linear", "pointsDisplay": "auto", "gapPolicy": "gap" },
          "colorModeType": { "colorPalette": "categorical", "seriesCustomColors": [] }
        },
        "querySettings": {}
      },
      "2": {
        "type": "data",
        "title": "Agent answer latency p50 / p90 / p99",
        "query": "fetch spans | filter dt.service.name == \"fieldops-backend\" and span.name == \"agent.run\" | makeTimeseries {p50 = percentile(duration, 50), p90 = percentile(duration, 90), p99 = percentile(duration, 99)}",
        "visualization": "lineChart",
        "visualizationSettings": {
          "dataMapping": { "time": "timeframe", "displayedFields": [], "series": ["p50", "p90", "p99"], "interval": "interval" },
          "axes": {
            "xAxis": { "label": "", "showLabel": false, "displayTimeFrame": "auto" },
            "yAxis": { "label": "duration", "min": {"mode": "auto"}, "max": {"mode": "auto"}, "scale": "linear", "showLabel": true }
          },
          "unitsOverrides": [
            { "identifier": "p50", "unitCategory": "time", "baseUnit": "nanosecond", "displayUnit": null, "decimals": null, "suffix": "", "delimiter": false },
            { "identifier": "p90", "unitCategory": "time", "baseUnit": "nanosecond", "displayUnit": null, "decimals": null, "suffix": "", "delimiter": false },
            { "identifier": "p99", "unitCategory": "time", "baseUnit": "nanosecond", "displayUnit": null, "decimals": null, "suffix": "", "delimiter": false }
          ],
          "seriesConfig": { "curve": "linear", "pointsDisplay": "auto", "gapPolicy": "gap" },
          "colorModeType": { "colorPalette": "categorical", "seriesCustomColors": [] }
        },
        "querySettings": {}
      },
      "3": {
        "type": "data",
        "title": "Tool duration & call count by tool",
        "query": "fetch spans | filter dt.service.name == \"fieldops-backend\" and startsWith(span.name, \"tool.\") | summarize {p50 = percentile(duration, 50), p95 = percentile(duration, 95), calls = count()}, by:{span.name}",
        "visualization": "categoricalBarChart",
        "visualizationSettings": {
          "categoryAxis": { "label": {"label": "tool", "showLabel": true}, "tickLayout": "horizontal" },
          "numericAxis": { "label": {"showLabel": true, "label": "duration / calls"}, "scale": "linear" },
          "dataMapping": { "displayedFields": ["span.name"], "values": ["p50", "p95", "calls"] },
          "valueSettings": { "valueRepresentation": "absolute" },
          "layout": { "groupMode": "grouped", "position": "horizontal" },
          "colorModeType": { "colorCategoryMode": "multi-color", "colorPalette": "categorical", "customCategoryColors": {} }
        },
        "querySettings": {}
      },
      "4": {
        "type": "data",
        "title": "Tokens in vs out by role",
        "query": "fetch spans | filter dt.service.name == \"fieldops-backend\" and span.name == \"agent.run\" | summarize {tokens_in = sum(gen_ai.usage.input_tokens), tokens_out = sum(gen_ai.usage.output_tokens)}, by:{user.role}",
        "visualization": "categoricalBarChart",
        "visualizationSettings": {
          "categoryAxis": { "label": {"label": "role", "showLabel": true}, "tickLayout": "horizontal" },
          "numericAxis": { "label": {"showLabel": true, "label": "tokens"}, "scale": "linear" },
          "dataMapping": { "displayedFields": ["user.role"], "values": ["tokens_in", "tokens_out"] },
          "valueSettings": { "valueRepresentation": "absolute" },
          "layout": { "groupMode": "grouped", "position": "horizontal" },
          "colorModeType": { "colorCategoryMode": "multi-color", "colorPalette": "categorical", "customCategoryColors": {} }
        },
        "querySettings": {}
      },
      "5": {
        "type": "data",
        "title": "Host CPU usage",
        "query": "timeseries cpu = avg(dt.host.cpu.usage), by:{dt.entity.host}",
        "visualization": "lineChart",
        "visualizationSettings": {
          "dataMapping": { "time": "timeframe", "displayedFields": ["dt.entity.host"], "series": ["cpu"], "interval": "interval" },
          "axes": {
            "xAxis": { "label": "", "showLabel": false, "displayTimeFrame": "auto" },
            "yAxis": { "label": "CPU %", "min": {"mode": "auto"}, "max": {"mode": "auto"}, "scale": "linear", "showLabel": true }
          },
          "unitsOverrides": [
            { "identifier": "cpu", "unitCategory": "percent", "baseUnit": "percent", "displayUnit": null, "decimals": 1, "suffix": "", "delimiter": false }
          ],
          "seriesConfig": { "curve": "linear", "pointsDisplay": "auto", "gapPolicy": "gap" },
          "colorModeType": { "colorPalette": "categorical", "seriesCustomColors": [] }
        },
        "querySettings": {}
      },
      "6": {
        "type": "data",
        "title": "Recent conversations (prompt + completion + tokens)",
        "query": "fetch spans, from:-1h | filter dt.service.name == \"fieldops-backend\" and span.name == \"agent.run\" | sort start_time desc | fields start_time, user.role, gen_ai.prompt, gen_ai.completion, gen_ai.usage.input_tokens, gen_ai.usage.output_tokens, gen_ai.usage.total_tokens, snowflake.request_id | limit 25",
        "visualization": "table",
        "visualizationSettings": {
          "table": {
            "colorThresholdTarget": "value",
            "columnOrder": ["start_time", "user.role", "gen_ai.prompt", "gen_ai.completion", "gen_ai.usage.input_tokens", "gen_ai.usage.output_tokens", "gen_ai.usage.total_tokens", "snowflake.request_id"],
            "hiddenColumns": [],
            "rowDensity": "comfortable",
            "sortBy": [],
            "columnWidthStrategy": "auto",
            "enableSparklines": false,
            "linewrapEnabled": true
          }
        },
        "querySettings": {}
      },
      "7": {
        "type": "data",
        "title": "Agent / tool log lines (OTLP)",
        "query": "fetch logs | filter service.name == \"fieldops-backend\" and (contains(content, \"tool invoked\") or contains(content, \"agent request\") or contains(content, \"tool result\")) | sort timestamp desc | fields timestamp, loglevel, content, trace_id | limit 30",
        "visualization": "table",
        "visualizationSettings": {
          "table": {
            "colorThresholdTarget": "value",
            "columnOrder": ["timestamp", "loglevel", "content", "trace_id"],
            "hiddenColumns": [],
            "rowDensity": "condensed",
            "sortBy": [],
            "columnWidthStrategy": "content",
            "enableSparklines": false,
            "linewrapEnabled": true
          }
        },
        "querySettings": {}
      },
      "8": {
        "type": "data",
        "title": "FastAPI HTTP server — POST /api/agent/run latency",
        "query": "fetch spans | filter dt.service.name == \"fieldops-backend\" and span.name == \"POST /api/agent/run\" and span.kind == \"server\" | makeTimeseries {p50 = percentile(duration, 50), p90 = percentile(duration, 90)}",
        "visualization": "lineChart",
        "visualizationSettings": {
          "dataMapping": { "time": "timeframe", "displayedFields": [], "series": ["p50", "p90"], "interval": "interval" },
          "axes": {
            "xAxis": { "label": "", "showLabel": false, "displayTimeFrame": "auto" },
            "yAxis": { "label": "duration", "min": {"mode": "auto"}, "max": {"mode": "auto"}, "scale": "linear", "showLabel": true }
          },
          "unitsOverrides": [
            { "identifier": "p50", "unitCategory": "time", "baseUnit": "nanosecond", "displayUnit": null, "decimals": null, "suffix": "", "delimiter": false },
            { "identifier": "p90", "unitCategory": "time", "baseUnit": "nanosecond", "displayUnit": null, "decimals": null, "suffix": "", "delimiter": false }
          ],
          "seriesConfig": { "curve": "linear", "pointsDisplay": "auto", "gapPolicy": "gap" },
          "colorModeType": { "colorPalette": "categorical", "seriesCustomColors": [] }
        },
        "querySettings": {}
      },
      "9": {
        "type": "data",
        "title": "Total tokens per minute",
        "query": "fetch spans | filter dt.service.name == \"fieldops-backend\" and span.name == \"agent.run\" | makeTimeseries tokens = sum(gen_ai.usage.total_tokens)",
        "visualization": "lineChart",
        "visualizationSettings": {
          "dataMapping": { "time": "timeframe", "displayedFields": [], "series": ["tokens"], "interval": "interval" },
          "axes": {
            "xAxis": { "label": "", "showLabel": false, "displayTimeFrame": "auto" },
            "yAxis": { "label": "tokens", "min": {"mode": "auto"}, "max": {"mode": "auto"}, "scale": "linear", "showLabel": true }
          },
          "seriesConfig": { "curve": "linear", "pointsDisplay": "auto", "gapPolicy": "gap" },
          "colorModeType": { "colorPalette": "categorical", "seriesCustomColors": [] }
        },
        "querySettings": {}
      },
      "10": {
        "type": "markdown",
        "content": "## Business & User Impact (RUM)\n\nWhat real users are doing in the SPA — adoption, engagement with the AI feature, and frontend performance. Built from `user.events` (`dt.rum.user_type == \"real_user\"`, scoped to the FieldOps Copilot page)."
      },
      "11": {
        "type": "data",
        "title": "Active users (distinct browser sessions over time)",
        "query": "fetch user.events | filter dt.rum.user_type == \"real_user\" and page.title == \"FieldOps Copilot\" | makeTimeseries active = countDistinct(dt.rum.browser.session_id)",
        "visualization": "lineChart",
        "visualizationSettings": {
          "dataMapping": { "time": "timeframe", "displayedFields": [], "series": ["active"], "interval": "interval" },
          "axes": {
            "xAxis": { "label": "", "showLabel": false, "displayTimeFrame": "auto" },
            "yAxis": { "label": "sessions", "min": {"mode": "auto"}, "max": {"mode": "auto"}, "scale": "linear", "showLabel": true }
          },
          "seriesConfig": { "curve": "linear", "pointsDisplay": "auto", "gapPolicy": "gap" },
          "colorModeType": { "colorPalette": "categorical", "seriesCustomColors": [] }
        },
        "querySettings": {}
      },
      "12": {
        "type": "data",
        "title": "AI invocations per minute (XHR /api/agent/run)",
        "query": "fetch user.events | filter dt.rum.user_type == \"real_user\" and page.title == \"FieldOps Copilot\" and url.path == \"/api/agent/run\" | makeTimeseries invocations = count()",
        "visualization": "lineChart",
        "visualizationSettings": {
          "dataMapping": { "time": "timeframe", "displayedFields": [], "series": ["invocations"], "interval": "interval" },
          "axes": {
            "xAxis": { "label": "", "showLabel": false, "displayTimeFrame": "auto" },
            "yAxis": { "label": "invocations", "min": {"mode": "auto"}, "max": {"mode": "auto"}, "scale": "linear", "showLabel": true }
          },
          "seriesConfig": { "curve": "linear", "pointsDisplay": "auto", "gapPolicy": "gap" },
          "colorModeType": { "colorPalette": "categorical", "seriesCustomColors": [] }
        },
        "querySettings": {}
      },
      "13": {
        "type": "data",
        "title": "AI engagement — prompts per session (top 10)",
        "query": "fetch user.events, from:-1h | filter dt.rum.user_type == \"real_user\" and page.title == \"FieldOps Copilot\" and url.path == \"/api/agent/run\" | summarize prompts = count(), by:{session = dt.rum.browser.session_id} | sort prompts desc | limit 10",
        "visualization": "categoricalBarChart",
        "visualizationSettings": {
          "categoryAxis": { "label": {"label": "session", "showLabel": true}, "tickLayout": "horizontal" },
          "numericAxis": { "label": {"showLabel": true, "label": "prompts"}, "scale": "linear" },
          "dataMapping": { "displayedFields": ["session"], "values": ["prompts"] },
          "valueSettings": { "valueRepresentation": "absolute" },
          "layout": { "groupMode": "grouped", "position": "horizontal" },
          "colorModeType": { "colorCategoryMode": "single-color", "colorPalette": "categorical", "customCategoryColors": {} }
        },
        "querySettings": {}
      },
      "14": {
        "type": "data",
        "title": "AI adoption — sessions that invoked the AI",
        "query": "fetch user.events, from:-1h | filter dt.rum.user_type == \"real_user\" and page.title == \"FieldOps Copilot\" | summarize total_sessions = countDistinct(dt.rum.browser.session_id), ai_sessions = countDistinct(if(url.path == \"/api/agent/run\", dt.rum.browser.session_id))",
        "visualization": "singleValue",
        "visualizationSettings": {
          "singleValue": {
            "showLabel": true,
            "label": "AI sessions / Total",
            "prefixIcon": "",
            "autoscale": true,
            "alignment": "center",
            "colorThresholdTarget": "value",
            "trend": { "trendType": "auto", "isVisible": false },
            "sparklineSettings": { "isVisible": false, "color": { "Default": "DEFAULT_DARK" } }
          }
        },
        "querySettings": {}
      },
      "15": {
        "type": "data",
        "title": "Page-load performance — First Contentful Paint (FCP)",
        "query": "fetch user.events | filter dt.rum.user_type == \"real_user\" and page.title == \"FieldOps Copilot\" and isNotNull(fcp.value) | makeTimeseries {p50 = percentile(fcp.value, 50), p90 = percentile(fcp.value, 90)}",
        "visualization": "lineChart",
        "visualizationSettings": {
          "dataMapping": { "time": "timeframe", "displayedFields": [], "series": ["p50", "p90"], "interval": "interval" },
          "axes": {
            "xAxis": { "label": "", "showLabel": false, "displayTimeFrame": "auto" },
            "yAxis": { "label": "FCP (ms)", "min": {"mode": "auto"}, "max": {"mode": "auto"}, "scale": "linear", "showLabel": true }
          },
          "seriesConfig": { "curve": "linear", "pointsDisplay": "auto", "gapPolicy": "gap" },
          "colorModeType": { "colorPalette": "categorical", "seriesCustomColors": [] }
        },
        "querySettings": {}
      },
      "16": {
        "type": "data",
        "title": "Recent AI invocations (per browser session)",
        "query": "fetch user.events, from:-1h | filter dt.rum.user_type == \"real_user\" and page.title == \"FieldOps Copilot\" and url.path == \"/api/agent/run\" | sort start_time desc | fields start_time, dt.rum.browser.session_id, geo.country.iso_code, browser.name, http.response.status_code, duration | limit 30",
        "visualization": "table",
        "visualizationSettings": {
          "table": {
            "colorThresholdTarget": "value",
            "columnOrder": ["start_time", "dt.rum.browser.session_id", "geo.country.iso_code", "browser.name", "http.response.status_code", "duration"],
            "hiddenColumns": [],
            "rowDensity": "condensed",
            "sortBy": [],
            "columnWidthStrategy": "auto",
            "enableSparklines": false,
            "linewrapEnabled": true
          }
        },
        "querySettings": {}
      }
    },
    "layouts": {
      "0":  { "x": 0,  "y": 0,  "w": 24, "h": 1 },
      "10": { "x": 0,  "y": 1,  "w": 24, "h": 2 },
      "11": { "x": 0,  "y": 3,  "w": 12, "h": 8 },
      "12": { "x": 12, "y": 3,  "w": 12, "h": 8 },
      "14": { "x": 0,  "y": 11, "w": 8,  "h": 8 },
      "13": { "x": 8,  "y": 11, "w": 16, "h": 8 },
      "15": { "x": 0,  "y": 19, "w": 12, "h": 8 },
      "16": { "x": 12, "y": 19, "w": 12, "h": 8 },
      "1":  { "x": 0,  "y": 27, "w": 12, "h": 8 },
      "2":  { "x": 12, "y": 27, "w": 12, "h": 8 },
      "8":  { "x": 0,  "y": 35, "w": 12, "h": 8 },
      "9":  { "x": 12, "y": 35, "w": 12, "h": 8 },
      "3":  { "x": 0,  "y": 43, "w": 12, "h": 8 },
      "4":  { "x": 12, "y": 43, "w": 12, "h": 8 },
      "5":  { "x": 0,  "y": 51, "w": 24, "h": 6 },
      "6":  { "x": 0,  "y": 57, "w": 24, "h": 14 },
      "7":  { "x": 0,  "y": 71, "w": 24, "h": 8 }
    },
    "settings": {
      "gridLayout": { "columnsCount": 24 }
    }
  }
}
